# Maintainer: tournierjc <https://github.com/tournierjc>
pkgname=lghub2
# Baseline for makepkg; pkgver() sets the real version from package.json + git.
# makepkg may rewrite this line — restore with: git checkout packaging/PKGBUILD
pkgver=0.1.0
pkgrel=4
pkgdesc="Cross-platform reimplementation of Logitech G Hub"
arch=('x86_64')
url="https://github.com/tournierjc/lghub2"
license=('custom:UNLICENSED')
depends=('electron' 'libusb')
makedepends=('nodejs>=22' 'npm' 'python' 'gcc')
options=(!debug !strip)
install="$pkgname.install"

# Prefer the parent checkout when this file lives in <repo>/packaging/, so `makepkg`
# does not build stale GitHub main (push first for reproducible remote builds).
_repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
if [[ -d "${_repo_root}/.git" ]]; then
  source=("${pkgname}::git+file://${_repo_root}")
else
  source=("${pkgname}::git+https://github.com/tournierjc/lghub2.git")
fi
sha256sums=('SKIP')

pkgver() {
  cd "$srcdir/$pkgname"
  # Do not use $pkgver here: makepkg may rewrite pkgver= and nesting breaks the next build.
  # Avoid node here: pkgver() can run before makedepends (nodejs) are installed.
  local _appver
  _appver=$(grep -m1 '"version"' package.json | sed -n 's/.*"version"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')
  printf '%s.r%s.g%s' \
    "$_appver" \
    "$(git rev-list --count HEAD)" \
    "$(git rev-parse --short=7 HEAD)"
}

build() {
  cd "$srcdir/$pkgname"

  npm ci

  local _electron_ver
  _electron_ver=$(electron --version | sed 's/^v//')
  ./node_modules/.bin/electron-rebuild --version "$_electron_ver"

  npm run build
  npm prune --omit=dev
}

package() {
  cd "$srcdir/$pkgname"

  install -dm755 "$pkgdir/usr/lib/$pkgname"
  cp -r dist    "$pkgdir/usr/lib/$pkgname/"
  cp -r assets  "$pkgdir/usr/lib/$pkgname/"
  cp -r node_modules "$pkgdir/usr/lib/$pkgname/"

  install -Dm644 assets/icon.png \
    "$pkgdir/usr/share/pixmaps/$pkgname.png"

  install -Dm755 /dev/stdin "$pkgdir/usr/bin/$pkgname" << 'EOF'
#!/bin/bash
exec electron /usr/lib/lghub2/dist/main/main.js "$@"
EOF

  install -Dm644 packaging/lghub2.desktop \
    "$pkgdir/usr/share/applications/$pkgname.desktop"

  install -Dm644 packaging/70-lghub2.rules \
    "$pkgdir/usr/lib/udev/rules.d/70-lghub2.rules"
}
